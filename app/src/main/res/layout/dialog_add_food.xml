<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_shopping_bag"
                app:tint="@color/dark_green" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Feed Item"
                android:textColor="@color/dark_green"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Feed Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Feed Name *"
            android:textColor="@color/dark_green"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/foodNameInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/rounded_corner"
            android:hint="e.g. Layer Feed Premium"
            android:textColor="@color/black"
            android:inputType="textCapWords"
            android:padding="12dp"
            android:textSize="14sp" />

        <!-- Description -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Description"
            android:textColor="@color/dark_green"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/foodDescInput"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/rounded_corner"
            android:gravity="top|start"
            android:hint="Short description of this feed"
            android:inputType="textMultiLine"
            android:textColor="@color/black"
            android:padding="12dp"
            android:textSize="14sp" />

        <!-- INV Number -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="INV Number"
            android:textColor="@color/dark_green"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/foodInvInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/rounded_corner"
            android:hint="#INV0001  (auto-generated if empty)"
            android:inputType="text"
            android:textColor="@color/black"
            android:padding="12dp"
            android:textSize="14sp" />

        <!-- Category -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Category"
            android:textColor="@color/dark_green"
            android:textSize="13sp"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/rounded_corner">

            <Spinner
                android:id="@+id/categorySpinner"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="10dp"
                android:paddingEnd="10dp" />
        </FrameLayout>

        <!-- Location -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Location / Shop"
            android:textColor="@color/dark_green"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/foodLocationInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/rounded_corner"
            android:hint="e.g. Shop 1"
            android:textColor="@color/black"
            android:inputType="textCapWords"
            android:padding="12dp"
            android:textSize="14sp" />

        <!-- Quantity + Unit Price side by side -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quantity"
                    android:textColor="@color/dark_green"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/foodQtyInput"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/rounded_corner"
                    android:hint="0"
                    android:textColor="@color/black"
                    android:inputType="numberDecimal"
                    android:padding="12dp"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Unit Price (Php)"
                    android:textColor="@color/dark_green"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/foodPriceInput"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/rounded_corner"
                    android:hint="0.00"
                    android:textColor="@color/black"
                    android:inputType="numberDecimal"
                    android:padding="12dp"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Status -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status"
            android:textColor="@color/dark_green"
            android:textSize="13sp"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/rounded_corner">

            <Spinner
                android:id="@+id/statusSpinner"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="10dp"
                android:paddingEnd="10dp" />
        </FrameLayout>

    </LinearLayout>
</ScrollView>