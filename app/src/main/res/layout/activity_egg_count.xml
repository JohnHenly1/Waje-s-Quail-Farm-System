<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_gray"
    tools:context=".EggCountActivity">

    <!-- ══════════════════════  HEADER  ══════════════════════ -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/dark_green"
        android:minHeight="?attr/actionBarSize"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:theme="?attr/actionBarTheme"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="8dp">

            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                android:scaleType="centerInside"
                app:srcCompat="@drawable/ic_arrow_back"
                app:tint="@color/white" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Egg Count &amp; Quality"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/liveTimeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12:00 PM\nApr 7, 2026"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:gravity="end" />

            <!-- Reset / refresh counts -->
            <ImageButton
                android:id="@+id/refreshButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Reset counts"
                android:scaleType="centerInside"
                app:srcCompat="@android:drawable/stat_notify_sync"
                app:tint="@color/white" />
        </LinearLayout>
    </androidx.appcompat.widget.Toolbar>

    <!-- ══════════════════════  SCROLLABLE BODY  ══════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottomNavContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ─────────────  STATUS BANNER (hidden by default)  ───────────── -->
            <TextView
                android:id="@+id/statusBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="#1B5E20"
                android:padding="10dp"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:visibility="gone"
                tools:text="Model loaded" />

            <!-- ─────────────  CAMERA CARD  ───────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="300dp">

                    <!-- Live camera preview -->
                    <androidx.camera.view.PreviewView
                        android:id="@+id/cameraPreview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <!-- Dim overlay when frame is frozen -->
                    <View
                        android:id="@+id/frozenOverlay"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#55000000"
                        android:visibility="gone" />

                    <!-- Bounding-box overlay -->
                    <com.example.exp1.DetectionOverlayView
                        android:id="@+id/detectionOverlay"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <!-- LIVE / ANALYZING / CAPTURED badge (top-left) -->
                    <TextView
                        android:id="@+id/liveScanLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|start"
                        android:layout_margin="10dp"
                        android:background="@drawable/rounded_dark_green"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="5dp"
                        android:text="● LIVE SCAN"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <!-- ─────────────  CAMERA CONTROL ROW  ───────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:gravity="center"
                android:orientation="horizontal">

                <!-- Capture current frame & analyze -->
                <Button
                    android:id="@+id/captureBtn"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/dark_green"
                    android:text="📷  Capture &amp; Analyze"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <!-- Retake: resume live scanning (visible only when frozen) -->
                <Button
                    android:id="@+id/retakeBtn"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:backgroundTint="#E65100"
                    android:text="↩  Retake"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <!-- Pick from gallery -->
                <Button
                    android:id="@+id/modeSwitchBtn"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:backgroundTint="#37474F"
                    android:text="Pick Photo"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- Save Collection button this is hidden until a capture is completed -->
            <Button
                android:id="@+id/saveCollectionBtn"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="#2E7D32"
                android:text="💾  Save Collection"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- ─────────────  Today's Count Card  ───────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_orange_gradient"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="28dp">

                    <FrameLayout
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:layout_marginBottom="10dp"
                        android:background="@drawable/circle_white"
                        android:backgroundTint="#33FFFFFF">
                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_gravity="center"
                            app:srcCompat="@drawable/lc_egg"
                            app:tint="@color/white" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/todayTotalValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/white"
                        android:textSize="56sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:alpha="0.9"
                        android:text="Total Eggs Detected"
                        android:textColor="@color/white"
                        android:textSize="15sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ─────────────  QUALITY DISTRIBUTION  ───────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="Quality Distribution"
                android:textColor="@color/black"
                android:textSize="17sp"
                android:textStyle="bold" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="22dp"
                android:columnCount="3">

                <!-- Grade A -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="4dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/white"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:layout_marginBottom="4dp"
                            android:background="#2E7D32" />
                        <TextView
                            android:id="@+id/gradeAValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#2E7D32"
                            android:textSize="26sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Grade A"
                            android:textColor="@color/dark_gray"
                            android:textSize="11sp" />
                        <TextView
                            android:id="@+id/gradeAPercent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0%"
                            android:textColor="#2E7D32"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Grade B -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_marginHorizontal="4dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/white"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:layout_marginBottom="4dp"
                            android:background="#F57F17" />
                        <TextView
                            android:id="@+id/gradeBValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#F57F17"
                            android:textSize="26sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Grade B"
                            android:textColor="@color/dark_gray"
                            android:textSize="11sp" />
                        <TextView
                            android:id="@+id/gradeBPercent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0%"
                            android:textColor="#F57F17"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Grade C -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="4dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/white"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:layout_marginBottom="4dp"
                            android:background="#C62828" />
                        <TextView
                            android:id="@+id/gradeCValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#C62828"
                            android:textSize="26sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Grade C"
                            android:textColor="@color/dark_gray"
                            android:textSize="11sp" />
                        <TextView
                            android:id="@+id/gradeCPercent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0%"
                            android:textColor="#C62828"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </GridLayout>

            <!-- ─────────────  COLLECTION HISTORY HEADER  ───────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Collection History"
                    android:textColor="@color/black"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/calendarBtn"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:srcCompat="@android:drawable/ic_menu_my_calendar"
                    app:tint="@color/dark_green" />

                <ImageButton
                    android:id="@+id/prevWeekBtn"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:srcCompat="@drawable/ic_arrow_back"
                    app:tint="@color/dark_green" />

                <TextView
                    android:id="@+id/weekRangeTxt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="8dp"
                    android:text="This Week"
                    android:textColor="@color/dark_gray"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/nextWeekBtn"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:srcCompat="@drawable/ic_arrow_forward"
                    app:tint="@color/dark_green" />
            </LinearLayout>

            <!-- Collection log rows injected here at runtime -->
            <LinearLayout
                android:id="@+id/collectionLogList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ══════════════════════  BOTTOM NAV  ══════════════════════ -->
    <LinearLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/dark_green"
        android:gravity="center"
        android:baselineAligned="false"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout android:id="@+id/homeButton"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:scaleType="centerInside"
                app:srcCompat="@drawable/ic_home" app:tint="@color/white" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/home" android:textColor="@color/white"
                android:textSize="10sp" android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/analyticsButton"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:scaleType="centerInside"
                app:srcCompat="@drawable/ic_chart" app:tint="@color/white" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/analytics" android:textColor="@color/white"
                android:textSize="10sp" android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/CameraButton"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:scaleType="centerInside"
                app:srcCompat="@drawable/ic_camera" app:tint="@color/white" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/camera" android:textColor="@color/white"
                android:textSize="10sp" android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/scheduleButton"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:scaleType="centerInside"
                app:srcCompat="@drawable/ic_schedule" app:tint="@color/white" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/schedule" android:textColor="@color/white"
                android:textSize="10sp" android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/profileButton"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:scaleType="centerInside"
                app:srcCompat="@drawable/ic_profile" app:tint="@color/white" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/profile" android:textColor="@color/white"
                android:textSize="10sp" android:layout_marginTop="2dp" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>