<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:maxHeight="520dp"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_users"
                app:tint="@color/dark_green"
                android:contentDescription="Add User Icon" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Add User"
                android:textColor="@color/dark_green"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Full Name"
            android:textColor="@color/dark_green"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/inviteName"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/rounded_corner"
            android:hint="Enter full name"
            android:inputType="textPersonName"
            android:padding="12dp"
            android:textSize="16sp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email Address"
            android:textColor="@color/dark_green"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/inviteEmail"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/rounded_corner"
            android:hint="Enter recipient email"
            android:inputType="textEmailAddress"
            android:padding="12dp"
            android:textSize="16sp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Birthday (optional)"
            android:textColor="@color/dark_green"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/inviteBirthday"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/rounded_corner"
            android:hint="MM/DD/YYYY"
            android:focusable="false"
            android:clickable="true"
            android:padding="12dp"
            android:textSize="16sp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Address (optional — fill all or leave all blank)"
            android:textColor="@color/dark_green"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/inviteAddressStreet"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/rounded_corner"
            android:hint="Street"
            android:inputType="textPostalAddress"
            android:padding="12dp"
            android:textSize="16sp"
            android:layout_marginBottom="10dp" />

        <EditText
            android:id="@+id/inviteAddressCity"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/rounded_corner"
            android:hint="City"
            android:inputType="text"
            android:padding="12dp"
            android:textSize="16sp"
            android:layout_marginBottom="10dp" />

        <EditText
            android:id="@+id/inviteAddressState"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/rounded_corner"
            android:hint="State / Province"
            android:inputType="text"
            android:padding="12dp"
            android:textSize="16sp"
            android:layout_marginBottom="10dp" />

        <EditText
            android:id="@+id/inviteAddressPostal"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/rounded_corner"
            android:hint="Postal Code"
            android:inputType="text"
            android:padding="12dp"
            android:textSize="16sp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Role"
            android:textColor="@color/dark_green"
            android:textSize="14sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/inviteRoleGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/radioInviteStaff"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Staff"
                android:checked="true"
                android:buttonTint="@color/dark_green"/>
        </RadioGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="The new user will set their own password when they open their invite. Everything above is filled in by you."
            android:textColor="@color/dark_green"
            android:alpha="0.7"
            android:textSize="12sp" />

    </LinearLayout>
</ScrollView>