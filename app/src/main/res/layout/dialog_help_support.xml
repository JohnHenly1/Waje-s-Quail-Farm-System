<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Help &amp; Support"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Getting Started"
            android:textColor="@color/dark_green"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="4dp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome to Waje's Quail Farm System. This app helps you manage your quail farm efficiently by tracking birds, eggs, feed, and tasks."
            android:textSize="14sp"
            android:textColor="@color/gray"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dashboard"
            android:textColor="@color/dark_green"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="4dp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="The dashboard provides a quick overview of your farm. You can see the current time, quick stats, and access shortcuts for inventory, egg counts, reports, and tasks."
            android:textSize="14sp"
            android:textColor="@color/gray"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Managing Tasks (Schedule)"
            android:textColor="@color/dark_green"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="4dp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Use the Schedule tab to add daily tasks like feeding, watering, or cleaning. You can set reminders and track task status (Pending, Ongoing, Done)."
            android:textSize="14sp"
            android:textColor="@color/gray"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Feed Inventory"
            android:textColor="@color/dark_green"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="4dp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Keep track of your feed stock levels. Mark items as Full, Medium, or Low. The system will alert you when stock is low."
            android:textSize="14sp"
            android:textColor="@color/gray"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Analytics"
            android:textColor="@color/dark_green"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="4dp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="View trends in egg production and farm performance over time using the charts in the Analytics section."
            android:textSize="14sp"
            android:textColor="@color/gray"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile &amp; Settings"
            android:textColor="@color/dark_green"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="4dp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Under Profile, you can update your farm stats via 'Farm Recalibration' or customize your 'Notification Preferences'."
            android:textSize="14sp"
            android:textColor="@color/gray"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contact Support"
            android:textColor="@color/dark_green"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="4dp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="If you encounter any issues, please contact our support team at support@wajequailfarm.com"
            android:textSize="14sp"
            android:textColor="@color/gray"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>