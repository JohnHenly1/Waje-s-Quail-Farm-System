<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:background="#F4F4F4"
    tools:layout_editor_absoluteX="0dp"
    tools:layout_editor_absoluteY="12dp">

    <!-- Log In Text Indicator -->
    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="Log In"
        android:textColor="#466d1d"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/Btn"
        android:layout_width="320dp"
        android:layout_height="52dp"
        android:layout_marginTop="288dp"
        android:backgroundTint="#466d1d"
        android:textColor="@color/white"
        android:text="Continue With Google"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.494"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageView" />

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:src="@drawable/logo_quailfarm"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView" />

    <!-- Bush1 -->

    <!-- Bush2 -->

    <ImageView
        android:id="@+id/desigbush"
        android:layout_width="287dp"
        android:layout_height="248dp"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="16dp"
        android:rotation="28"
        android:src="@drawable/design_bush"
        app:layout_constraintEnd_toStartOf="@+id/desigbush2"
        app:layout_constraintTop_toBottomOf="@+id/Btn" />

    <ImageView
        android:id="@+id/desigbush2"
        android:layout_width="285dp"
        android:layout_height="243dp"
        android:layout_marginStart="228dp"
        android:layout_marginTop="32dp"
        android:rotation="-15"
        android:src="@drawable/design_bush"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/Btn" />
</androidx.constraintlayout.widget.ConstraintLayout>