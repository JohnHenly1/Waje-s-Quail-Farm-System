<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@android:color/white">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="User Management"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/dark_green"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="24dp" />

    <!-- Action Buttons Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="28dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRoleLimits"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Limits"
            android:textSize="11sp"
            app:cornerRadius="12dp"
            app:strokeColor="@color/dark_green"
            android:textColor="@color/dark_green"
            android:layout_marginEnd="4dp"
            android:paddingVertical="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:textAllCaps="false"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPendingReq"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Pending"
            android:textSize="11sp"
            app:cornerRadius="12dp"
            app:strokeColor="@color/dark_green"
            android:textColor="@color/dark_green"
            android:layout_marginHorizontal="2dp"
            android:paddingVertical="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:textAllCaps="false"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewCodes"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Codes"
            android:textSize="11sp"
            app:cornerRadius="12dp"
            app:strokeColor="@color/dark_green"
            android:textColor="@color/dark_green"
            android:layout_marginHorizontal="2dp"
            android:paddingVertical="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:textAllCaps="false"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnInviteNew"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Invite"
            android:textSize="11sp"
            app:cornerRadius="12dp"
            app:backgroundTint="@color/dark_green"
            android:layout_marginStart="4dp"
            android:paddingVertical="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:textAllCaps="false"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="APPROVED MEMBERS"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@color/gray"
        android:letterSpacing="0.1"
        android:layout_marginBottom="12dp"
        android:layout_marginStart="2dp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="200dp">

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:visibility="gone"
            android:indeterminateTint="@color/dark_green" />

        <TextView
            android:id="@+id/errorTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Failed to load users"
            android:textColor="@color/logout_red"
            android:visibility="gone"
            android:layout_gravity="center"
            android:textSize="14sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvUserList"
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:clipToPadding="false"
            android:paddingBottom="12dp"
            android:overScrollMode="never" />
    </FrameLayout>

</LinearLayout>
