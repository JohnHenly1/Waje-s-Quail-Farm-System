<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_shopping_bag"
                app:tint="@color/dark_green" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Supplement Item"
                android:textColor="@color/dark_green"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Selector for Existing Items -->
        <TextView
            android:id="@+id/selectItemLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Existing Item (Optional)"
            android:textColor="@color/dark_green"
            android:textSize="13sp"
            android:textStyle="bold" />

        <FrameLayout
            android:id="@+id/selectItemContainer"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/rounded_corner">

            <Spinner
                android:id="@+id/existingItemsSpinner"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="10dp"
                android:paddingEnd="10dp" />
        </FrameLayout>

        <!-- Product Name (required) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Product Name *"
            android:textColor="@color/dark_green"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/foodNameInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/rounded_corner"
            android:hint="e.g. Vitamin Supplement A"
            android:textColor="@color/black"
            android:inputType="textCapWords"
            android:padding="12dp"
            android:textSize="14sp" />

        <!-- Description (optional) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Description"
            android:textColor="@color/dark_green"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/foodDescInput"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/rounded_corner"
            android:gravity="top|start"
            android:hint="Short description (optional)"
            android:inputType="textMultiLine"
            android:textColor="@color/black"
            android:padding="12dp"
            android:textSize="14sp" />

        <!-- INV Number (existing, keep) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="INV Number"
            android:textColor="@color/dark_green"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/foodInvInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/rounded_corner"
            android:hint="#INV0001  (auto-generated if empty)"
            android:inputType="text"
            android:textColor="@color/black"
            android:padding="12dp"
            android:textSize="14sp" />

        <!-- Shop Detail (optional) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Shop Detail"
            android:textColor="@color/dark_green"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/foodLocationInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/rounded_corner"
            android:hint="e.g. Shop 1 (optional)"
            android:textColor="@color/black"
            android:inputType="textCapWords"
            android:padding="12dp"
            android:textSize="14sp" />

        <!-- Quantity + Unit selector row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/foodQtyLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quantity"
                    android:textColor="@color/dark_green"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/foodQtyInput"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/rounded_corner"
                    android:hint="0"
                    android:textColor="@color/black"
                    android:inputType="number"
                    android:padding="12dp"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Unit selector (Bottle / Box) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Unit"
                    android:textColor="@color/dark_green"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/rounded_corner">

                    <Spinner
                        android:id="@+id/supplementUnitSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp" />
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Price per Unit -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Price per Unit (Php)"
            android:textColor="@color/dark_green"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/foodPriceInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/rounded_corner"
            android:hint="0.00"
            android:textColor="@color/black"
            android:inputType="numberDecimal"
            android:padding="12dp"
            android:textSize="14sp" />

        <!-- Total Price (auto-calculated, read-only) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total Price (Auto-calculated)"
            android:textColor="@color/dark_green"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/totalPriceDisplay"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/rounded_corner"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="₱ 0.00"
            android:textColor="@color/dark_gray"
            android:textSize="14sp" />

        <!-- Hidden fields for compatibility -->
        <Spinner
            android:id="@+id/categorySpinner"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:visibility="gone" />

        <Spinner
            android:id="@+id/statusSpinner"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>