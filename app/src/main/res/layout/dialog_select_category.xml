<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/white"
    android:padding="24dp">

    <!-- Icon + Title row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_shopping_bag"
            app:tint="@color/dark_green" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="Add Inventory Item"
            android:textColor="@color/dark_green"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Instruction -->
    <TextView
        android:id="@+id/categoryInstructionText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select a category before adding item details"
        android:textColor="@color/dark_gray"
        android:textSize="13sp"
        android:layout_marginBottom="20dp" />

    <!-- Feeding option -->
    <LinearLayout
        android:id="@+id/categoryFeedOption"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/rounded_corner"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="14dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_shopping_bag"
            app:tint="@color/dark_green" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Feeding"
                android:textColor="@color/dark_green"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sacks · feed supplies"
                android:textColor="@color/dark_gray"
                android:textSize="12sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/feedSelectedIcon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_check_circle"
            app:tint="@color/dark_green"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Supplements option -->
    <LinearLayout
        android:id="@+id/categorySupplementOption"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@drawable/rounded_corner"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="14dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_shopping_bag"
            app:tint="@color/dark_green" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Supplements"
                android:textColor="@color/dark_green"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bottles / Boxes · health supplements"
                android:textColor="@color/dark_gray"
                android:textSize="12sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/supplementSelectedIcon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_check_circle"
            app:tint="@color/dark_green"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>